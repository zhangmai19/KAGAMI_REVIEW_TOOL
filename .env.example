# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAlex polite pool (provides faster API access)
OPENALEX_EMAIL=your_email@example.com

# Semantic Scholar API Key (optional, for higher rate limits)
# SEMANTIC_SCHOLAR_API_KEY=your_key_here

# Crossref polite pool
CROSSREF_EMAIL=your_email@example.com

# PubMed / NCBI (required for Entrez API)
# NCBI_API_KEY=your_ncbi_key_here

# Commercial database API keys (optional)
# WOS_API_KEY=your_wos_key_here
# SCOPUS_API_KEY=your_scopus_key_here

# SerpAPI for Google Scholar (optional)
# SERPAPI_KEY=your_serpapi_key_here

# Default LLM model
DEFAULT_LLM_MODEL=gpt-4o-mini
